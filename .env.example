# Copy to .env for local dev (never commit real secrets).
# Production: fly secrets set KEY=value -a animations-composer

# Cloudflare account + D1 (primary waitlist / future users & render jobs)
CLOUDFLARE_ACCOUNT_ID=f23d40d6e8e5a8ba907fec5d01d3f37b
D1_DATABASE_ID=f7c44f86-9b4c-4e5e-9033-00fb12c44587
# Account API token with Account → D1:Edit (required for production waitlist)
CLOUDFLARE_API_TOKEN=

# Cloudflare R2 (S3 API) — future render packs; optional waitlist fallback
R2_ACCOUNT_ID=f23d40d6e8e5a8ba907fec5d01d3f37b
R2_BUCKET=animations
R2_ENDPOINT=https://f23d40d6e8e5a8ba907fec5d01d3f37b.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://harkirat155.github.io
